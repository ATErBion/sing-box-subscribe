      "tag":"auto",
      "type":"urltest",
      "outbounds":[
        "{all}"
      ],
      "filter":[
        {"action":"exclude","keywords":["剩余|套餐|订阅|官网|机场|网址|网站|地址|发布|过期|到期|时间|有效|@"]}
      ],
      "url": "http://cp.cloudflare.com",
      "interval": "10m",
      "tolerance": 50
